# Copy to .env and fill in (never commit .env)

DATABASE_URL=postgresql://USER:PASSWORD@HOST/neondb?sslmode=require

# Long random string for signing login tokens
JWT_SECRET_KEY=change-me-to-a-long-random-string

# Approve/reject landlord KYC via POST /api/admin/kyc/review (header X-Admin-Key)
KYC_ADMIN_KEY=

# Email OTP (optional). Example: Gmail app password + smtp.gmail.com:587
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# SMTP_FROM=
# SMTP_USE_TLS=1
